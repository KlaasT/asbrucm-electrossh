{
  "name": "asbru-cm-electro-ssh",
  "title": "Asbru-CM ElectroSSH",
  "version": "0.0.1",
  "type": "module",
  "main": "main.js",
  "author": {
    "name": "Klaas Tammling",
    "email": "klaas@tammling.hamburg"
  },
  "description": "An SSH connection manager built with Electron and Alpine.js",
  "scripts": {
    "start": "vite",
    "electron:dev": "vite --host & wait-for-localhost 5173 && NODE_ENV=development electron .",
    "build": "vite build",
    "dist": "npm run build && electron-builder",
    "dist:linux": "npm run build && electron-builder --linux"
  },
  "dependencies": {
    "alpinejs": "^3.14.9",
    "bootstrap": "^5.3.3",
    "electron-store": "^8.1.0",
    "nanoid": "^3.3.9",
    "node-pty": "^1.1.0-beta31",
    "node-ssh": "^13.2.0",
    "xterm": "^5.3.0",
    "xterm-addon-fit": "^0.8.0"
  },
  "devDependencies": {
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3",
    "vite": "^5.4.14",
    "vite-plugin-electron": "^0.29.0",
    "wait-for-localhost": "^4.1.0"
  },
  "build": {
    "appId": "net.asbru-cm.ssh",
    "productName": "Asbru-CM ElectroSSH",
    "win": {
      "icon": "images/icon.ico",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "linux": {
      "icon": "images/icon.png",
      "target": [
        "AppImage"
      ],
      "category": "Utility"
    },
    "files": [
      "main.js",
      "dist/**/*",
      "dist-electron/preload.mjs"
    ]
  }
}
